{
  "name": "gmaps-extractor",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "node scripts/clear-next-dev-lock-stale.mjs && next dev",
    "dev:unlock": "node scripts/clear-next-dev-lock-stale.mjs",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next && rm -rf node_modules/.cache",
    "clean:win": "powershell -ExecutionPolicy Bypass -File ./clean-cache.ps1",
    "dev:clean": "npm run clean:win && npm run dev",
    "setup:scheduled-function": "tsx scripts/setup-scheduled-function.ts",
    "anti-spam:worker": "tsx scripts/anti-spam-worker.ts",
    "backfill:transfer-balances": "tsx scripts/backfill-transfer-balances.ts",
    "cron:install": "tsx scripts/linux/install-linux-cron.ts",
    "cron:list": "tsx scripts/linux/list-scheduled-jobs.ts",
    "cron:run": "tsx scripts/linux/run-scheduled-job.ts",
    "test:resolve-expired": "tsx scripts/test-resolve-expired.ts",
    "test:wa-audio-official": "tsx scripts/test-whatsapp-official-audio.ts",
    "run:netlify-resolve-expired": "tsx scripts/run-netlify-resolve-expired.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "next": "^16.0.7",
    "node-fetch": "^3.3.2",
    "pm2": "^6.0.13",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.5",
    "@netlify/plugin-nextjs": "^5.14.4",
    "@tailwindcss/postcss": "^4",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.13",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
