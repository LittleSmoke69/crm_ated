# Copie para .env e preencha os valores reais (nunca commite o .env).

# ── Supabase ─────────────────────────────────────────────────────────────────
# CRÍTICO: NEXT_PUBLIC_SUPABASE_ANON_KEY = chave "anon" / "public" do painel Supabase.
# NUNCA coloque a service_role aqui — ela vai para o bundle do browser e quebra o build.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_apenas_server_side

# ── Integrações ──────────────────────────────────────────────────────────────
CRM_API_KEY=
WASENDER_API_KEY=
VTURB_ANALYTICS_TOKEN=
VTURB_ANALYTICS_VERSION=v1
GEMINI_API_KEY=
CRON_SECRET=
LOG_META_ADS_HIERARCHY=0

# ── URLs públicas e internas ─────────────────────────────────────────────────
SITE_URL=https://zaploto.com
URL=https://zaploto.com
NEXT_PUBLIC_SITE_URL=https://zaploto.com

# ── Fila interna (webhook Evolution) ─────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ── Secrets dos crons ────────────────────────────────────────────────────────
INTERNAL_CRON_SECRET=
GROUP_FETCH_JOB_SECRET=
TRANSFER_RESOLVE_CRON_SECRET=
ANTI_SPAM_CRON_SECRET=

# ── Anti-spam worker (tempo real) ────────────────────────────────────────────
ANTI_SPAM_POLL_MS=800
ANTI_SPAM_BATCH_SIZE=50

# ── Evolution Webhook Auth ───────────────────────────────────────────────────
EVOLUTION_WEBHOOK_SECRET_PROD=
