# Copie para .env e preencha os valores reais (nunca commite o .env).

# ── Supabase ─────────────────────────────────────────────────────────────────
# ANON_KEY = chave "anon"/"public". NUNCA use a service_role em NEXT_PUBLIC_* (vaza no bundle).
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_apenas_server_side

# ── URLs ─────────────────────────────────────────────────────────────────────
SITE_URL=https://zaploto.com
URL=https://zaploto.com
NEXT_PUBLIC_SITE_URL=https://zaploto.com

# ── Escopo da instalação ─────────────────────────────────────────────────────
# full (padrão) = stack completo com Evolution e fila de disparo
# modelagem     = só CRM + chat WhatsApp oficial + Meta Ads (sem Evolution)
NEXT_PUBLIC_ZAPLOTO_APP_SCOPE=modelagem

# ── Integrações ──────────────────────────────────────────────────────────────
CRM_API_KEY=
WASENDER_API_KEY=
GEMINI_API_KEY=
VTURB_ANALYTICS_TOKEN=
VTURB_ANALYTICS_VERSION=v1
LOG_META_ADS_HIERARCHY=0

# ── Fila / worker ────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
ANTI_SPAM_POLL_MS=800
ANTI_SPAM_BATCH_SIZE=50

# ── Secrets dos crons ────────────────────────────────────────────────────────
CRON_SECRET=
INTERNAL_CRON_SECRET=
GROUP_FETCH_JOB_SECRET=
TRANSFER_RESOLVE_CRON_SECRET=
ANTI_SPAM_CRON_SECRET=

# ── Webhook Auth ─────────────────────────────────────────────────────────────
EVOLUTION_WEBHOOK_SECRET_PROD=
# WhatsApp Oficial: App Secret que valida X-Hub-Signature-256. Vazio = usa o webhook_secret do config.
WHATSAPP_OFFICIAL_APP_SECRET=
